# Lark / Feishu app credentials (server-side only)
LARK_APP_ID=
LARK_APP_SECRET=

# Lark Base targets
LARK_BASE_APP_TOKEN=
LARK_TABLE_ID=

# Lark Base field names (must match column names in your Base exactly)
LARK_FIELD_NAME=Full Name
LARK_FIELD_EMAIL=Email
LARK_FIELD_BRANCH=Branch
LARK_FIELD_CLOCKIN=Clock-in

# Override only if your tenant is on Feishu (China): https://open.feishu.cn
LARK_API_BASE=https://open.larksuite.com
